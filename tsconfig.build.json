{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src"
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "test",
    "dist",
    "admin-ui",
    "packages",
    "plugins",
    "providers",
    "benchmarks",
    "docs",
    "terraform-provider-idenplane",
    "themes",
    "scripts",
    "prisma",
    "**/*spec.ts",
    "**/*.mock.ts",
    "**/__mocks__/**",
    "prisma.config.ts"
  ]
}
