// ─── RISK ASSESSMENT ──────────────────────────────────────

model LoginRiskAssessment {
  id                String   @id @default(uuid())
  loginEventId      String?  @map("login_event_id")
  userId            String   @map("user_id")
  realmId           String   @map("realm_id")
  riskScore         Int      @map("risk_score")
  riskLevel         String   @map("risk_level")     // LOW, MEDIUM, HIGH, CRITICAL
  signals           Json                              // Array of RiskSignal objects
  action            String                            // ALLOW, STEP_UP, BLOCK
  ipAddress         String?  @map("ip_address")
  userAgent         String?  @map("user_agent")
  geoLocation       String?  @map("geo_location")   // "city, country" or null
  deviceFingerprint String?  @map("device_fingerprint")
  createdAt         DateTime @default(now()) @map("created_at")

  realm Realm @relation(fields: [realmId], references: [id], onDelete: Cascade)
  // Issue #462: userId had no @relation, leaving the foreign key disconnected
  // from the User model. Added explicit relation so Prisma can enforce the FK
  // and generate typed includes.
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([realmId, createdAt])
  @@index([riskLevel])
  @@map("login_risk_assessments")
}

model UserLoginProfile {
  id                  String   @id @default(uuid())
  userId              String   @unique @map("user_id")
  realmId             String   @map("realm_id")
  knownIps            Json     @default("[]") @map("known_ips")
  knownDevices        Json     @default("[]") @map("known_devices")
  loginTimes          Json     @default("[]") @map("login_times")
  lastLocations       Json     @default("[]") @map("last_locations")
  avgLoginFrequency   Float    @default(0)   @map("avg_login_frequency")
  updatedAt           DateTime @updatedAt    @map("updated_at")

  realm Realm @relation(fields: [realmId], references: [id], onDelete: Cascade)
  // Issue #462: userId had no @relation, leaving the foreign key disconnected
  // from the User model. Added explicit relation so Prisma can enforce the FK
  // and generate typed includes.
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([realmId])
  @@map("user_login_profiles")
}




// ─── ORGANIZATIONS ────────────────────────────────────────

model Organization {
  id              String   @id @default(uuid())
  realmId         String   @map("realm_id")
  realm           Realm    @relation(fields: [realmId], references: [id], onDelete: Cascade)
  name            String
  slug            String
  displayName     String?  @map("display_name")
  description     String?
  enabled         Boolean  @default(true)

  // Branding
  logoUrl         String?  @map("logo_url")
  primaryColor    String?  @map("primary_color")

  // Auth policies
  requireMfa      Boolean  @default(false) @map("require_mfa")

  // Domain verification
  verifiedDomains String[] @map("verified_domains")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  members         OrganizationMember[]
  invitations     OrganizationInvitation[]
  ssoConnections  OrganizationSsoConnection[]

  @@unique([realmId, slug])
  @@map("organizations")
}

model OrganizationMember {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String       @map("user_id")
  role           String       @default("member")
  joinedAt       DateTime     @default(now()) @map("joined_at")

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("organization_members")
}

model OrganizationInvitation {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String       @default("member")
  token          String       @unique
  expiresAt      DateTime     @map("expires_at")
  acceptedAt     DateTime?    @map("accepted_at")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@map("organization_invitations")
}

model OrganizationSsoConnection {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           String
  name           String
  enabled        Boolean      @default(true)
  config         Json
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@map("organization_sso_connections")
}

model RevokedToken {
  jti       String   @id
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime @default(now()) @map("revoked_at")

  @@index([expiresAt])
  @@map("revoked_tokens")
}

model ServiceAccount {
  id          String   @id @default(uuid())
  realmId     String   @map("realm_id")
  name        String
  description String?
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Issue #462: realmId had no @relation, causing Prisma to treat it as an
  // unconnected scalar. Added explicit relation to Realm with cascade delete.
  realm   Realm    @relation(fields: [realmId], references: [id], onDelete: Cascade)
  apiKeys ApiKey[]

  @@unique([realmId, name])
  @@index([realmId])
  @@map("service_accounts")
}

model ApiKey {
  id               String    @id @default(uuid())
  serviceAccountId String    @map("service_account_id")
  keyPrefix        String    @map("key_prefix")
  keyHash          String    @map("key_hash")
  name             String?
  scopes           String[]
  expiresAt        DateTime? @map("expires_at")
  lastUsedAt       DateTime? @map("last_used_at")
  requestCount     Int       @default(0) @map("request_count")
  revoked          Boolean   @default(false)
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  serviceAccount ServiceAccount @relation(fields: [serviceAccountId], references: [id], onDelete: Cascade)

  @@index([serviceAccountId])
  @@index([keyPrefix])
  @@map("api_keys")
}
