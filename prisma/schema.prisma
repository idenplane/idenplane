// ─── NHI (Non-Human Identities) ───────────────────────────

enum NhiIdentityType {
  MACHINE_TO_MACHINE
  IOT_DEVICE
  SERVICE
  AI_AGENT
}

enum NhiLifecycleStatus {
  PROVISIONING
  ACTIVE
  SUSPENDED
  DECOMMISSIONED
}

enum NhiCredentialType {
  API_KEY
  CERTIFICATE
  JWT
  OAUTH
  MTLS
}

model NhiIdentity {
  id                     String             @id @default(uuid())
  realmId                String             @map("realm_id")
  identityType           NhiIdentityType    @default(MACHINE_TO_MACHINE) @map("identity_type")
  name                   String
  description            String?
  enabled                Boolean            @default(true)
  lifecycleStatus        NhiLifecycleStatus @default(PROVISIONING) @map("lifecycle_status")
  suspendedAt            DateTime?          @map("suspended_at")
  decommissionedAt       DateTime?          @map("decommissioned_at")
  certificateSubject     String?            @map("certificate_subject")
  certificateFingerprint String?            @map("certificate_fingerprint")
  certificateNotBefore   DateTime?          @map("certificate_not_before")
  certificateNotAfter    DateTime?          @map("certificate_not_after")
  agentPurpose           String?            @map("agent_purpose")
  permissionScopes       String[]           @default([]) @map("permission_scopes")
  metadata               Json               @default("{}") @map("metadata")
  tags                   String[]           @default([]) @map("tags")
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")

  realm       Realm           @relation(fields: [realmId], references: [id], onDelete: Cascade)
  credentials NhiCredential[]
  usageStats  NhiUsageStats?

  @@unique([realmId, name])
  @@index([realmId])
  @@index([lifecycleStatus])
  @@map("nhi_identities")
}

model NhiCredential {
  id                  String            @id @default(uuid())
  nhiIdentityId       String            @map("nhi_identity_id")
  credentialType      NhiCredentialType @default(API_KEY) @map("credential_type")
  name                String
  keyPrefix           String?           @map("key_prefix")
  keyHash             String?           @map("key_hash")
  certificatePem      String?           @map("certificate_pem")
  certificateChain    String?           @map("certificate_chain")
  privateKeyPem       String?           @map("private_key_pem")
  jwtSigningAlgorithm String?           @map("jwt_signing_algorithm")
  jwtIssuer           String?           @map("jwt_issuer")
  jwtAudience         String?           @map("jwt_audience")
  expiresAt           DateTime?         @map("expires_at")
  rotatedAt           DateTime?         @map("rotated_at")
  rotationRequired    Boolean           @default(false) @map("rotation_required")
  enabled             Boolean           @default(true)
  revoked             Boolean           @default(false)
  revokedAt           DateTime?         @map("revoked_at")
  lastUsedAt          DateTime?         @map("last_used_at")
  requestCount        Int               @default(0) @map("request_count")
  allowedIpRanges     String[]          @default([]) @map("allowed_ip_ranges")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  nhiIdentity NhiIdentity @relation(fields: [nhiIdentityId], references: [id], onDelete: Cascade)

  @@unique([nhiIdentityId, name])
  @@index([nhiIdentityId])
  @@index([keyPrefix])
  @@index([expiresAt])
  @@map("nhi_credentials")
}

model NhiCredentialPolicy {
  id                   String            @id @default(uuid())
  realmId              String            @map("realm_id")
  name                 String
  description          String?
  enabled              Boolean           @default(true)
  priority             Int               @default(0)
  credentialType       NhiCredentialType @default(API_KEY) @map("credential_type")
  rotationIntervalDays Int               @default(90) @map("rotation_interval_days")
