  rateLimitPerMinute   Int?              @map("rate_limit_per_minute")
  requireCertificate   Boolean           @default(false) @map("require_certificate")
  requireIpRestriction Boolean           @default(false) @map("require_ip_restriction")
  requireAuditLogging  Boolean           @default(true) @map("require_audit_logging")
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")

  realm Realm @relation(fields: [realmId], references: [id], onDelete: Cascade)

  @@unique([realmId, name])
  @@index([realmId])
  @@index([realmId, priority])
  @@map("nhi_credential_policies")
}

model NhiAuditLog {
  id            String   @id @default(uuid())
  realmId       String   @map("realm_id")
  nhiIdentityId String   @map("nhi_identity_id")
  action        String
  credentialId  String?  @map("credential_id")
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent")
  success       Boolean  @default(true)
  errorCode     String?  @map("error_code")
  details       Json?
  createdAt     DateTime @default(now()) @map("created_at")

  realm Realm @relation(fields: [realmId], references: [id], onDelete: Cascade)

  @@index([realmId])
  @@index([nhiIdentityId])
  @@index([action])
  @@index([createdAt])
  @@map("nhi_audit_logs")
}

model NhiUsageStats {
  id            String    @id @default(uuid())
  nhiIdentityId String    @unique @map("nhi_identity_id")
  totalRequests Int       @default(0) @map("total_requests")
  lastActiveAt  DateTime? @map("last_active_at")
  successCount  Int       @default(0) @map("success_count")
  errorCount    Int       @default(0) @map("error_count")
  lastSuccessfulAt DateTime? @map("last_successful_at")
  lastFailedAt      DateTime? @map("last_failed_at")
  oldestCredentialAgeDays Int? @map("oldest_credential_age_days")
  newestCredentialAgeDays Int? @map("newest_credential_age_days")
  credentialsExpiringSoon Int @default(0) @map("credentials_expiring_soon")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  nhiIdentity NhiIdentity @relation(fields: [nhiIdentityId], references: [id], onDelete: Cascade)

  @@map("nhi_usage_stats")
}

// ─── ACCOUNT DELETION (GDPR) ───────────────────────────────

model PendingDeletion {
  id                String    @id @default(uuid())
  userId            String    @unique @map("user_id")
  requestedAt       DateTime  @default(now()) @map("requested_at")
  scheduledAt       DateTime  @map("scheduled_at")
  gracePeriodDays   Int       @map("grace_period_days")
  status            String    @default("pending") // pending | processing | completed | cancelled
  cancelledAt       DateTime? @map("cancelled_at")
  cancelledBy       String?   @map("cancelled_by")
  completedAt       DateTime? @map("completed_at")
  exportStatus      String?   @map("export_status") // requested | generating | ready | expired
  exportRequestedAt DateTime? @map("export_requested_at")
  exportGeneratedAt DateTime? @map("export_generated_at")
  exportUrl         String?   @map("export_url")
  ipAddress         String?   @map("ip_address")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([scheduledAt])
  @@map("pending_deletions")
}

// ─── CONSENT (GDPR) ────────────────────────────────────────

model ConsentCategory {
  id                  String   @id @default(uuid())
  realmId             String   @map("realm_id")
  key                 String
  displayName         String   @map("display_name")
  description         String?
  required            Boolean  @default(false)
  configurableByUser  Boolean  @default(true) @map("configurable_by_user")
  showInAccountPortal Boolean  @default(true) @map("show_in_account_portal")
  order               Int      @default(0)
  enabled             Boolean  @default(true)
  // OIDC scope names this category governs. Used to tag consent grants with
  // their category for per-category statistics. Empty = unconfigured: the
  // category then governs the scope whose name equals its `key` (convention
  // default). Setting any scope here disables that key fallback for this row.
  scopes              String[] @default([])
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  realm    Realm           @relation(fields: [realmId], references: [id], onDelete: Cascade)
  policies ConsentPolicy[]

  @@unique([realmId, key])
  @@index([realmId])
  @@map("consent_categories")
}

model ConsentPolicy {
  id          String    @id @default(uuid())
  categoryId  String    @map("category_id")
  version     String
  content     String?
  isActive    Boolean   @default(false) @map("is_active")
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  category ConsentCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@index([categoryId, isActive])
  @@map("consent_policies")
}

model UserConsentHistory {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  clientId      String   @map("client_id")
  action        String // GRANTED | REVOKED | UPDATED
  scopes        String[] @default([])
  policyVersion String?  @map("policy_version")
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent")
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([clientId])
  @@index([createdAt])
  @@map("user_consent_history")
}

// ─── THEME BUILDER ─────────────────────────────────────────

model Theme {
  id          String    @id @default(uuid())
  realmId     String    @map("realm_id")
  name        String
  displayName String?   @map("display_name")
  description String?
  themeType   String    @default("login") @map("theme_type") // login | account | email | full
  version     Int       @default(1)
  published   Boolean   @default(false)
  publishedAt DateTime? @map("published_at")
  styles      Json      @default("{}")
  components  Json      @default("[]")
  assets      Json      @default("{}")
  settings    Json      @default("{}")
  createdBy   String?   @map("created_by")
  updatedBy   String?   @map("updated_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  realm    Realm          @relation(fields: [realmId], references: [id], onDelete: Cascade)
  versions ThemeVersion[]

  @@unique([realmId, name])
  @@index([realmId])
  @@map("themes")
}

model ThemeVersion {
  id         String   @id @default(uuid())
  themeId    String   @map("theme_id")
  version    Int
  changes    String?
  checksum   String
  styles     Json     @default("{}")
  components Json     @default("[]")
  assets     Json     @default("{}")
  settings   Json     @default("{}")
  createdBy  String?  @map("created_by")
  createdAt  DateTime @default(now()) @map("created_at")

  theme Theme @relation(fields: [themeId], references: [id], onDelete: Cascade)

  @@unique([themeId, version])
  @@index([themeId])
  @@map("theme_versions")
}

// ─── UPGRADE AUDIT ─────────────────────────────────────────

model UpgradeAuditLog {
  id                String    @id @default(uuid())
  fromVersion       String    @map("from_version")
  toVersion         String    @map("to_version")
  status            String // IN_PROGRESS | COMPLETED | FAILED | ROLLBACK_COMPLETED | ROLLBACK_FAILED
  startedAt         DateTime  @default(now()) @map("started_at")
  completedAt       DateTime? @map("completed_at")
  initiatedBy       String    @map("initiated_by")
  backupId          String?   @map("backup_id")
  backupPath        String?   @map("backup_path")
  backupSize        String?   @map("backup_size")
  ipAddress         String?   @map("ip_address")
  dryRun            Boolean   @default(false) @map("dry_run")
  rollbackTriggered Boolean   @default(false) @map("rollback_triggered")
  details           Json?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([startedAt])
  @@index([fromVersion, toVersion])
  @@map("upgrade_audit_log")
}

// ─── RATE LIMIT ENTRIES (cluster-safe fallback) ────────────────

model RateLimitEntry {
  id        String   @id @default(uuid())
  key       String   @unique @map("key")
  minuteCount      Int      @default(0) @map("minute_count")
  minuteWindowStart DateTime @default(now()) @map("minute_window_start")
  hourCount        Int      @default(0) @map("hour_count")
  hourWindowStart   DateTime @default(now()) @map("hour_window_start")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([key])
  @@index([minuteWindowStart])
  @@index([hourWindowStart])
  @@map("rate_limit_entries")
}
