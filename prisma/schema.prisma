  @@unique([realmId, name])
  @@map("user_federations")
}

model UserFederationMapper {
  id            String  @id @default(uuid())
  federationId  String  @map("federation_id")
  name          String
  mapperType    String  @map("mapper_type")
  ldapAttribute String  @map("ldap_attribute")
  userAttribute String  @map("user_attribute")
  config        Json    @default("{}")

  createdAt DateTime @default(now()) @map("created_at")

  federation UserFederation @relation(fields: [federationId], references: [id], onDelete: Cascade)

  @@unique([federationId, name])
  @@map("user_federation_mappers")
}

