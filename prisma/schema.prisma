  createdAt         DateTime @default(now()) @map("created_at")

  realm Realm @relation(fields: [realmId], references: [id], onDelete: Cascade)
  // Issue #462: userId had no @relation, leaving the foreign key disconnected
  // from the User model. Added explicit relation so Prisma can enforce the FK
  // and generate typed includes.
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([realmId, createdAt])
  @@index([riskLevel])
  @@map("login_risk_assessments")
