  @@unique([credentialId])
  @@index([userId])
  @@map("webauthn_credentials")
}

// ─── IDENTITY PROVIDERS (Social Login) ───────────────────

model IdentityProvider {
  id           String  @id @default(uuid()) @db.VarChar(36)
  realmId      String  @map("realm_id") @db.VarChar(36)
  alias        String  @db.VarChar(191)
