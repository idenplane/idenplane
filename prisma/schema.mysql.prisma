}

model NhiCredentialPolicy {
  id                   String            @id @default(uuid()) @db.VarChar(36)
  realmId              String            @map("realm_id") @db.VarChar(36)
  name                 String
  description          String?
  enabled              Boolean           @default(true)
  priority             Int               @default(0)
  credentialType       NhiCredentialType @default(API_KEY) @map("credential_type")
  rotationIntervalDays Int               @default(90) @map("rotation_interval_days")
  rotationBeforeDays   Int               @default(7) @map("rotation_before_days")
  autoRotate           Boolean           @default(false) @map("auto_rotate")
  maxCredentialAgeDays Int               @default(365) @map("max_credential_age_days")
  maxRequestsPerDay    Int?              @map("max_requests_per_day")
  maxRequestsPerMonth  Int?              @map("max_requests_per_month")
  rateLimitPerMinute   Int?              @map("rate_limit_per_minute")
  requireCertificate   Boolean           @default(false) @map("require_certificate")
  requireIpRestriction Boolean           @default(false) @map("require_ip_restriction")
  requireAuditLogging  Boolean           @default(true) @map("require_audit_logging")
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")

  realm Realm @relation(fields: [realmId], references: [id], onDelete: Cascade)

  @@unique([realmId, name])
  @@index([realmId])
  @@index([realmId, priority])
  @@map("nhi_credential_policies")
}

model NhiAuditLog {
  id            String   @id @default(uuid()) @db.VarChar(36)
  realmId       String   @map("realm_id") @db.VarChar(36)
  nhiIdentityId String   @map("nhi_identity_id") @db.VarChar(36)
  action        String
  credentialId  String?  @map("credential_id") @db.VarChar(36)
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent")
  success       Boolean  @default(true)
  errorCode     String?  @map("error_code")
  details       Json?
  createdAt     DateTime @default(now()) @map("created_at")

  realm Realm @relation(fields: [realmId], references: [id], onDelete: Cascade)

  @@index([realmId])
  @@index([nhiIdentityId])
  @@index([action])
  @@index([createdAt])
  @@map("nhi_audit_logs")
}

model NhiUsageStats {
  id            String    @id @default(uuid()) @db.VarChar(36)
  nhiIdentityId String    @unique @map("nhi_identity_id") @db.VarChar(36)
  totalRequests Int       @default(0) @map("total_requests")
  lastActiveAt  DateTime? @map("last_active_at")
  successCount  Int       @default(0) @map("success_count")
  errorCount    Int       @default(0) @map("error_count")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  nhiIdentity NhiIdentity @relation(fields: [nhiIdentityId], references: [id], onDelete: Cascade)

  @@map("nhi_usage_stats")
}

// ─── THEME BUILDER ─────────────────────────────────────────

model Theme {
  id          String    @id @default(uuid()) @db.VarChar(36)
  realmId     String    @map("realm_id") @db.VarChar(36)
  name        String
  displayName String?   @map("display_name")
  description String?
  themeType   String    @default("login") @map("theme_type")
  version     Int       @default(1)
  published   Boolean   @default(false)
  publishedAt DateTime? @map("published_at")
  styles      Json      @default("{}")
  components  Json      @default("[]")
  assets      Json      @default("{}")
  settings    Json      @default("{}")
  createdBy   String?   @map("created_by")
  updatedBy   String?   @map("updated_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  realm    Realm          @relation(fields: [realmId], references: [id], onDelete: Cascade)
  versions ThemeVersion[]

  @@unique([realmId, name])
  @@index([realmId])
  @@map("themes")
}

model ThemeVersion {
  id         String   @id @default(uuid()) @db.VarChar(36)
  themeId    String   @map("theme_id") @db.VarChar(36)
  version    Int
  changes    String?
  checksum   String
  styles     Json     @default("{}")
  components Json     @default("[]")
  assets     Json     @default("{}")
  settings   Json     @default("{}")
  createdBy  String?  @map("created_by")
  createdAt  DateTime @default(now()) @map("created_at")

  theme Theme @relation(fields: [themeId], references: [id], onDelete: Cascade)

  @@unique([themeId, version])
  @@index([themeId])
  @@map("theme_versions")
}

// ─── UPGRADE AUDIT ─────────────────────────────────────────

model UpgradeAuditLog {
  id                String    @id @default(uuid()) @db.VarChar(36)
  fromVersion       String    @map("from_version")
  toVersion         String    @map("to_version")
  status            String
  startedAt         DateTime  @default(now()) @map("started_at")
  completedAt       DateTime? @map("completed_at")
  initiatedBy       String    @map("initiated_by")
  backupId          String?   @map("backup_id")
  backupPath        String?   @map("backup_path")
  backupSize        String?   @map("backup_size")
  ipAddress         String?   @map("ip_address")
  dryRun            Boolean   @default(false) @map("dry_run")
  rollbackTriggered Boolean   @default(false) @map("rollback_triggered")
  details           Json?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([startedAt])
  @@index([fromVersion, toVersion])
  @@map("upgrade_audit_log")
}
