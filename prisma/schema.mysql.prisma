model PendingAction {
  id        String   @id @default(uuid()) @db.VarChar(36)
  tokenHash String   @unique @map("token_hash") @db.VarChar(191)
  type      String   // "mfa_challenge" | "consent_request"
  // MySQL: Json maps to JSON column
  data      Json
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("pending_actions")
}

// ─── WEBHOOKS ────────────────────────────────────────────

model Webhook {
  id          String  @id @default(uuid()) @db.VarChar(36)
  realmId     String  @map("realm_id") @db.VarChar(36)
  realm       Realm   @relation(fields: [realmId], references: [id], onDelete: Cascade)
  url         String  @db.Text
  secret      String
  enabled     Boolean @default(true)
  // MySQL: JSON array
  eventTypes  Json    @default("[]") @map("event_types")
  description String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  deliveries WebhookDelivery[]

  @@map("webhooks")
}

model WebhookDelivery {
  id          String   @id @default(uuid()) @db.VarChar(36)
  webhookId   String   @map("webhook_id") @db.VarChar(36)
  webhook     Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  eventType   String   @map("event_type")
  // MySQL: Json maps to JSON column
  payload     Json
  statusCode  Int?     @map("status_code")
  response    String?  @db.Text
  success     Boolean  @default(false)
  attempts    Int      @default(0)
  lastAttempt DateTime? @map("last_attempt")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([webhookId, createdAt])
  @@map("webhook_deliveries")
}

/// Persistent outbox queue for webhook events (Issue #338).
model WebhookEvent {
  id          String   @id @default(uuid()) @db.VarChar(36)
  realmId     String   @map("realm_id") @db.VarChar(36)
  eventType   String   @map("event_type")
  // MySQL: Json maps to JSON column
  payload     Json
  /// PENDING | PROCESSING | DELIVERED | FAILED
  status      String   @default("PENDING") @db.VarChar(16)
  attempts    Int      @default(0)
  maxAttempts Int      @default(4)   @map("max_attempts")
  nextRetryAt DateTime @default(now()) @map("next_retry_at")
  lastError   String?  @map("last_error") @db.Text

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  @@index([status, nextRetryAt])
  @@index([realmId, createdAt])
  @@map("webhook_events")
}

// ─── ADMIN EVENTS ────────────────────────────────────────

model AdminEvent {
