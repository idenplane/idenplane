  required    Boolean  @default(false) @map("required")
  placeholder String?  @map("placeholder")
  helpText    String?  @map("help_text")
  options     Json     @default("[]") @map("options") // for select type (MySQL JSON)
  validationPattern String? @map("validation_pattern")
  defaultValue String?  @map("default_value")
  sortOrder   Int      @default(0) @map("sort_order")
  enabled     Boolean  @default(true) @map("enabled")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([realmId, name])
  @@index([realmId])
  @@map("registration_fields")
}
