  "scripts": {
    "build": "nest build",
    "admin:dev": "cd admin-ui && npm run dev",
    "admin:build": "cd admin-ui && npm run build",
    "build:all": "npm run admin:build && nest build && cp -r admin-ui/dist dist/admin-ui",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"src/**/*.ts\" --ignore-pattern '**/*.spec.ts' --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "postinstall": "prisma generate",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:seed": "npx ts-node prisma/seed.ts",
    "db:setup": "npx prisma migrate dev && npx ts-node prisma/seed.ts"
  },
