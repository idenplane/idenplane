# ─── Benchmark Configuration ──────────────────────────────────────────────────
#
# Target Idenplane instance to benchmark
TARGET_URL=http://localhost:3000

# Admin API key for authenticated requests
ADMIN_API_KEY=REPLACE_ME_WITH_YOUR_ADMIN_API_KEY

# ─── Load Test Parameters ───────────────────────────────────────────────────────
#
# Number of virtual users (concurrent connections)
VUS=50

# Test duration in seconds
DURATION=60s

# Ramp-up time in seconds (0 = instant)
RAMP_UP=10s

# ─── Database (for test data setup) ──────────────────────────────────────────
#
# Connection string for benchmark database setup
DATABASE_URL=postgresql://idenplane:idenplane@localhost:5432/idenplane

# ─── Output ───────────────────────────────────────────────────────────────────
#
# Results directory (relative to benchmarks/)
RESULTS_DIR=./results

# JSON summary output file
SUMMARY_FILE=./results/summary.json