{
  "name": "idenplane-cli",
  "version": "1.0.1",
  "description": "CLI tool for managing an Idenplane IAM server",
  "type": "module",
  "bin": {
    "idenplane": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup && node scripts/fix-node-imports.mjs",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test dist/tests/*.test.js"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "chalk": "^5.4.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.10.7"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "idenplane",
    "cli",
    "iam",
    "identity",
    "admin",
    "oauth2",
    "oidc"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/idenplane/idenplane.git",
    "directory": "packages/idenplane-cli"
  },
  "publishConfig": {
    "access": "public"
  }
}
