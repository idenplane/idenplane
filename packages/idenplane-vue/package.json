{
  "name": "idenplane-vue",
  "version": "1.0.1",
  "description": "Vue SDK for Idenplane Identity and Access Management Server",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "peerDependencies": {
    "idenplane-sdk": ">=1.0.0",
    "vue": ">=3.0.0",
    "vue-router": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "vue-router": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@vue/test-utils": "^2.4.0",
    "idenplane-sdk": "file:../idenplane-js",
    "jsdom": "^29.0.1",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "idenplane",
    "oauth2",
    "oidc",
    "vue",
    "vue3",
    "authentication",
    "composables"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/idenplane/idenplane.git",
    "directory": "packages/idenplane-vue"
  },
  "publishConfig": {
    "access": "public"
  }
}
