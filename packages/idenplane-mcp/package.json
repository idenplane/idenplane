{
  "name": "@idenplane/mcp",
  "version": "0.1.0",
  "description": "MCP server for Idenplane IAM — manage identities in natural language",
  "type": "module",
  "bin": {
    "idenplane-mcp": "dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/integration.mjs",
    "test:smoke": "node --test tests/smoke.mjs",
    "test:all": "node --test tests/smoke.mjs tests/integration.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.15.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.10.7"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "idenplane",
    "mcp",
    "iam",
    "identity",
    "oauth2",
    "oidc",
    "model-context-protocol"
  ],
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/idenplane/idenplane.git",
    "directory": "packages/idenplane-mcp"
  },
  "publishConfig": {
    "access": "public"
  }
}
